{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build + Upload + Monitor (USB)",
            "type": "shell",
            "command": "pio",
            "args": [
                "run",
                "--target", "upload",
                "--target", "monitor"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false,
                "showReuseMessage": false
            },
            "problemMatcher": ["$platformio"]
        },
        {
            "label": "Build Only",
            "type": "shell",
            "command": "pio",
            "args": ["run"],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": ["$platformio"]
        },
        {
            "label": "Monitor Only",
            "type": "shell",
            "command": "pio",
            "args": ["device", "monitor", "--baud", "115200"],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false,
                "showReuseMessage": false
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "Build & Package OTA Firmware",
            "type": "shell",
            "command": "powershell",
            "args": ["-ExecutionPolicy", "Bypass", "-File", "package.ps1", "D"],
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": true,
                "showReuseMessage": false
            },
            "problemMatcher": []
        }
    ]
}
